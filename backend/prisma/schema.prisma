generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  profile      Profile?
  roles        UserRole[]
  applications Application[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  role   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Profile {
  id             String  @id
  userId         String  @unique
  fullName       String?
  phone          String?
  branch         String?
  graduationYear Int?
  cgpa           Float?
  backlogs       Int     @default(0)
  skills         String  @default("[]")
  bio            String?
  resumeUrl      String?
  readinessScore Int     @default(0)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              String        @id @default(uuid())
  name            String
  roleTitle       String?
  packageLpa      Float?
  location        String?
  deadline        DateTime?
  minCgpa         Float?
  maxBacklogs     Int?
  allowedBranches String        @default("[]")
  requiredSkills  String        @default("[]")
  createdAt       DateTime      @default(now())
  applications    Application[]
}

model Application {
  id        String   @id @default(uuid())
  studentId String
  companyId String
  status    String   @default("Applied")
  appliedAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([studentId, companyId])
}
